{
  "name": "@anil-labs/lightbox-gallery-react",
  "version": "0.1.1",
  "description": "React bindings for @anil-labs/lightbox-gallery-core — a modern lightbox gallery with zoom, swipe, thumbnails, slideshow and video support.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"covered by @anil-labs/lightbox-gallery-core\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "lightbox",
    "gallery",
    "image",
    "zoom",
    "carousel"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Er. Anil Kumar Thakur <anilkumarthakur60@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anilkumarthakur60/lightbox-gallery.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/anilkumarthakur60/lightbox-gallery/tree/main/packages/react#readme",
  "bugs": "https://github.com/anilkumarthakur60/lightbox-gallery/issues",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anil-labs/lightbox-gallery-core": "workspace:^"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2"
  }
}
