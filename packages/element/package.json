{
  "name": "@anil-labs/lightbox-gallery-element",
  "version": "0.1.0",
  "description": "Web Component (<lightbox-gallery>) for @anil-labs/lightbox-gallery-core — works in any framework or plain HTML via a script tag.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": true,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"covered by @anil-labs/lightbox-gallery-core\"",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "keywords": [
    "web-component",
    "custom-element",
    "lightbox",
    "gallery",
    "image",
    "zoom",
    "carousel"
  ],
  "license": "MIT",
  "author": "Er. Anil Kumar Thakur <anilkumarthakur60@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anilkumarthakur60/lightbox-gallery.git",
    "directory": "packages/element"
  },
  "homepage": "https://github.com/anilkumarthakur60/lightbox-gallery/tree/main/packages/element#readme",
  "bugs": "https://github.com/anilkumarthakur60/lightbox-gallery/issues",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anil-labs/lightbox-gallery-core": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
